# Set to production when deploying (blocks db:seed, enables production behavior)
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/crm
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:5173
# After Gmail/Slack OAuth, users are redirected to basicsos.com/connections/success?provider=slack (no frontend hosting needed).
# To use your own success page: CONNECTIONS_SUCCESS_URL=https://yoursite.com/connected
# If you host your own app and want the redirect in-app: FRONTEND_URL=https://app.example.com
# AI gateway URL. For self-hosting, set to your gateway.
BASICSOS_API_URL=https://api.basicsos.com
# Comma-separated CORS + Better Auth trusted origins for production (e.g. https://api.yourcompany.com)
ALLOWED_ORIGINS=
# Required for production: 32-byte base64 or hex key for encrypting stored API keys
API_KEY_ENCRYPTION_KEY=generate-32-byte-base64-or-hex
PORT=3001

# --- Server-level AI key (optional, fallback when no admin UI config exists) ---
# Option A: BasicsOS key for all users
# SERVER_BASICS_API_KEY=bos_live_sk_...
# Option B: BYOK (bring your own key) — routes through api.basicsos.com with BYOK headers
# SERVER_BYOK_PROVIDER=openai   # openai | anthropic | gemini
# SERVER_BYOK_API_KEY=sk-...

# --- Optional: Transcription BYOK (voice STT) — used when org has no Deepgram key in Settings ---
# SERVER_TRANSCRIPTION_BYOK_PROVIDER=deepgram
# SERVER_TRANSCRIPTION_BYOK_API_KEY=your-deepgram-api-key

# --- Password reset email: use SMTP or SERVER_BASICS_API_KEY (SMTP takes precedence) ---
# SMTP (e.g. Resend, SendGrid, custom SMTP)
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=465
# MAIL_USER=resend
# MAIL_PASS=re_...
# MAIL_FROM=Basics <noreply@yourdomain.com>
# Or use SERVER_BASICS_API_KEY above — it will call POST /v1/email/send for reset emails

# --- Combined deployment (server + web from same origin) ---
# STATIC_DIR=/app/dist
